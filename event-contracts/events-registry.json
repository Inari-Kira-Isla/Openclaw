{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://muse-core.event-schemas/events-registry.json",
  "title": "Events Registry",
  "description": "Registry of all Muse Core event types",
  "version": "1.0.0",
  "categories": {
    "data-ingestion": {
      "description": "Events related to data ingestion and collection",
      "events": [
        {
          "type": "data.file.created",
          "version": "1.0.0",
          "description": "New file created in workspace"
        },
        {
          "type": "data.web.fetched",
          "version": "1.0.0",
          "description": "Web content fetched"
        }
      ]
    },
    "knowledge-update": {
      "description": "Events related to knowledge base updates",
      "events": [
        {
          "type": "knowledge.memory.stored",
          "version": "1.0.0",
          "description": "Memory stored to knowledge base"
        },
        {
          "type": "knowledge.context.updated",
          "version": "1.0.0",
          "description": "Context updated for session"
        }
      ]
    },
    "action-trigger": {
      "description": "Events that trigger actions",
      "events": [
        {
          "type": "action.agent.spawned",
          "version": "1.0.0",
          "description": "New sub-agent spawned"
        },
        {
          "type": "action.tool.invoked",
          "version": "1.0.0",
          "description": "Tool execution triggered"
        }
      ]
    },
    "feedback": {
      "description": "Feedback and acknowledgment events",
      "events": [
        {
          "type": "feedback.user.response",
          "version": "1.0.0",
          "description": "User feedback received"
        },
        {
          "type": "feedback.validation.pass",
          "version": "1.0.0",
          "description": "Validation passed"
        }
      ]
    }
  },
  "registeredEvents": [
    "data.file.created",
    "data.web.fetched",
    "knowledge.memory.stored",
    "knowledge.context.updated",
    "action.agent.spawned",
    "action.tool.invoked",
    "feedback.user.response",
    "feedback.validation.pass"
  ]
}
