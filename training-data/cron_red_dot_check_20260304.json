{
  "task_type": "cron_monitoring",
  "task_name": "red_dot_check",
  "description": "定時檢查系統異常節點和預警狀態",
  "trigger": "cron:07:20",
  "steps": [
    {
      "action": "list_nodes",
      "tool": "nodes",
      "expected_result": "節點列表"
    },
    {
      "action": "check_gateway_status",
      "tool": "exec",
      "command": "openclaw status --json",
      "expected_result": "系統狀態JSON"
    },
    {
      "action": "generate_report",
      "tool": "write",
      "output": "memory/red-dot-YYYYMMDD.md",
      "template": "紅點預警報告"
    }
  ],
  "success_criteria": [
    "節點狀態正常",
    "無錯誤/警告",
    "報告已生成"
  ],
  "frequency": "daily",
  "priority": "low",
  "created": "2026-03-04",
  "example_output": {
    "status": "✅ 無紅點預警",
    "anomalies": 0,
    "warnings": 0,
    "errors": 0
  }
}
