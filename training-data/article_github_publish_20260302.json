{
  "task_type": "article_publishing",
  "date": "2026-03-02",
  "description": "將 AI 評測文章上傳到 GitHub 並生成公開連結",
  "steps": [
    {
      "step": 1,
      "action": "建立文章檔案",
      "details": {
        "location": "~/.openclaw/workspace/articles/",
        "format": "Markdown",
        "frontmatter": ["title", "date", "author", "category", "description"]
      }
    },
    {
      "step": 2,
      "action": "初始化 Git",
      "details": {
        "commands": [
          "git status",
          "git add <file>",
          "git commit -m '<message>'"
        ]
      }
    },
    {
      "step": 3,
      "action": "推送到遠端",
      "details": {
        "if_no_remote": "git remote add origin <repo_url>",
        "push_command": "git push -u origin <branch>"
      }
    },
    {
      "step": 4,
      "action": "生成公開連結",
      "details": {
        "format": "https://github.com/<owner>/<repo>/blob/<branch>/<path>"
      }
    }
  ],
  "example_input": "Perplexity Computer 評測文章",
  "example_output": "https://github.com/Inari-Kira-Isla/openclaw-workspace/blob/master/articles/perplexity-computer-review.md",
  "tags": ["github", "article", "publishing", "automation"],
  "repeatable": true,
  "success_rate": "100%"
}
