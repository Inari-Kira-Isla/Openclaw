{
  "task_type": "system_health_check",
  "description": "檢查系統狀態並記錄異常",
  "trigger": "scheduled (heartbeat)",
  "steps": [
    {"action": "run_openclaw_status", "tool": "exec", "params": {"command": "openclaw status"}},
    {"action": "check_error_logs", "tool": "exec", "params": {"command": "openclaw logs --limit 100 | grep -i error"}},
    {"action": "verify_services", "tool": "exec", "params": {"command": "openclaw gateway status"}}
  ],
  "expected_output": "System health report with status of gateway, node, agents, sessions",
  "frequency": "daily"
}
