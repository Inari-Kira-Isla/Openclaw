{
  "task_type": "performance_monitoring_alert",
  "description": "效能監控警報處理 - 系統資源檢查與異常偵測",
  "trigger": "scheduled (heartbeat 30m)",
  "context": {
    "time": "2026-03-01 23:33 Asia/Macau",
    "source": "cron-event"
  },
  "steps": [
    {
      "action": "check_system_load",
      "tool": "exec",
      "params": {"command": "top -l 1 -n 0 | head -20"},
      "expected_keys": ["Load Avg", "CPU usage", "PhysMem"]
    },
    {
      "action": "check_api_latency",
      "tool": "exec",
      "params": {"command": "curl -o /dev/null -s -w '%{time_total}' https://api.minimax.io -k --connect-timeout 5"},
      "expected": "< 1s response time"
    },
    {
      "action": "check_gateway_health",
      "tool": "exec",
      "params": {"command": "openclaw status"},
      "expected_keys": ["Gateway", "Agents", "Sessions"]
    },
    {
      "action": "log_results",
      "tool": "write",
      "params": {"path": "memory/performance.md", "template": "performance log entry"}
    },
    {
      "action": "send_alert",
      "tool": "message",
      "params": {"action": "send", "condition": "anomaly_detected"},
      "fallback": "log_only_if_gateway_failed"
    }
  ],
  "examples": [
    {
      "input": "📉 效能監控警報：1.檢查系統響應時間 2.檢查記憶體使用 3.檢查API延遲",
      "analysis": {
        "load_avg": "3.17 (偏高)",
        "memory_used": "93%",
        "api_latency": "894ms (異常)",
        "gateway": "正常"
      },
      "expected_actions": [
        "記錄異常項目到 memory/performance.md",
        "嘗試發送警報到群組（如失敗則僅記錄）"
      ],
      "output": "✅ 記錄完成"
    },
    {
      "input": "System: Emergency Check",
      "expected": "✅ System healthy"
    }
  ],
  "anomaly_thresholds": {
    "load_avg_15m": 2.5,
    "memory_usage_percent": 90,
    "api_latency_ms": 500
  },
  "frequency": "30 minutes"
}
