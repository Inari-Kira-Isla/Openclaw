{
  "name": "向量化排程系統 (優化版)",
  "description": "錯峰向量化管理，避開 rate limit",
  "rateLimit": {
    "avoidPeakMinutes": [0, 15, 30, 45],
    "maxConcurrent": 2,
    "cooldownSeconds": 10
  },
  "tasks": {
    "sync-quick": {
      "cron": "*/17 * * * *",
      "agent": "memory-agent",
      "priority": "high",
      "description": "快速同步新筆記 (偏移到17分)",
      "maxDuration": "5m",
      "enabled": true
    },
    "sync-full": {
      "cron": "*/31 * * * *",
      "agent": "cynthia",
      "priority": "high",
      "description": "完整同步+驗證 (偏移到31分)",
      "maxDuration": "10m",
      "enabled": true
    },
    "deep-embed": {
      "cron": "0 * * * *",
      "agent": "memory-agent",
      "priority": "medium",
      "description": "每小時深度向量化",
      "maxDuration": "15m",
      "enabled": true
    },
    "quality-check": {
      "cron": "0 4 * * *",
      "agent": "cynthia",
      "priority": "low",
      "description": "每日品質檢查",
      "maxDuration": "30m",
      "enabled": true
    }
  },
  "stagger": {
    "enabled": true,
    "offset_pattern": "*/17",
    "description": "使用質數偏移減少衝突"
  },
  "monitoring": {
    "alertThreshold": 80,
    "trackTokens": true,
    "logErrors": true
  },
  "fallback": {
    "ifRateLimited": "skip",
    "retryAfterMinutes": 5
  }
}
